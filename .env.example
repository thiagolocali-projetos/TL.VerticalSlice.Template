# ============================================================
# TL.VerticalSlice.Template Configuration
# ============================================================
# Copy this file to .env and update values for your environment
# DO NOT commit the actual .env file (add it to .gitignore)

# ============================================================
# DATABASE
# ============================================================
DB_SERVER=localhost,1433
DB_NAME=TLVerticalSliceTemplate
DB_USER=sa
DB_PASSWORD=Password@2024

# ============================================================
# JWT Authentication
# ============================================================
JWT_SECRET_KEY=your-secret-key-min-32-chars-replace-this-in-production
JWT_ISSUER=TL.VerticalSlice.Template
JWT_AUDIENCE=TL.VerticalSlice.Template.Users
JWT_EXPIRATION_MINUTES=60

# ============================================================
# OPTIONAL: Redis Caching
# Uncomment in Program.cs to enable
# ============================================================
# REDIS_CONNECTION=localhost:6379

# ============================================================
# OPTIONAL: RabbitMQ Message Broker
# Uncomment in Program.cs to enable
# ============================================================
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest

# ============================================================
# OPTIONAL: Kafka Event Streaming
# Uncomment in Program.cs to enable
# ============================================================
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ============================================================
# OPTIONAL: Seq Structured Logging
# Uncomment in Program.cs to enable
# ============================================================
# SEQ_URL=http://localhost:5341

# ============================================================
# OPTIONAL: Jaeger Distributed Tracing
# Uncomment in Program.cs to enable
# ============================================================
# JAEGER_ENDPOINT=http://localhost:4317
